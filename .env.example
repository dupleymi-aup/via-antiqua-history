# Auth
JWT_SECRET=change-this-to-a-random-string
DB_PATH=data/app.db

# Site
NEXT_PUBLIC_SITE_URL=https://via-antiqua.maestro7it.ru

# Email (optional - test mode used by default)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@via-antiqua.ru
EMAIL_TEST_MODE=false

# Node environment
NODE_ENV=development

# FastPay Connect Configuration
FASTPAY_API_KEY=your-fastpay-api-key
FASTPAY_WEBHOOK_SECRET=your-webhook-secret
FASTPAY_API_URL=https://api.fastpay.example.com/v1
FASTPAY_SBP_PHONE=+79150480249
SUBSCRIPTION_PRICE=999

# QR code generation (optional — uses qrserver.com by default)
QR_CODE_API_URL=https://api.qrserver.com/v1/create-qr-code/
